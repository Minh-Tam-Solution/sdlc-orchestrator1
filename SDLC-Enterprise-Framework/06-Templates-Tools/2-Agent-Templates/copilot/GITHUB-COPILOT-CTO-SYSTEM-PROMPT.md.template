async function optimizedEndpoint(request) {
  // Parallel processing
  const [data1, data2] = await Promise.all([
    fetchData1(),
    fetchData2()
  ]);

  // Caching layer
  const cached = await cache.get(request.key);
  if (cached) return cached;

  // Optimized query
  const result = await db.query(
    optimizedQuery,
    { indexes: true }
  );

  // Cache result
  await cache.set(request.key, result, 3600);

  return result;
}
