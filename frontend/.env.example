# SDLC Orchestrator Landing Page - Environment Variables
# Copy this file to .env.local and fill in the values

# Mixpanel Analytics Token (optional - analytics disabled if not set)
NEXT_PUBLIC_MIXPANEL_TOKEN=

# API Base URL (for registration, checkout, etc.)
NEXT_PUBLIC_API_URL=https://api.sdlc.nhatquangholding.com

