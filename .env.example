# SDLC Orchestrator - Environment Variables Template
# Copy this file to .env and update values

# ============================================================================
# Database (PostgreSQL)
# ============================================================================
POSTGRES_PASSWORD=changeme_secure_password_min_16_chars
DATABASE_URL=postgresql://sdlc_user:${POSTGRES_PASSWORD}@localhost:5432/sdlc_orchestrator

# ============================================================================
# Redis
# ============================================================================
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0

# ============================================================================
# MinIO (S3-Compatible Storage)
# ============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_changeme_16_chars
MINIO_ENDPOINT=localhost:9000
MINIO_USE_SSL=false
MINIO_BUCKET_EVIDENCE=evidence-vault
MINIO_BUCKET_ORCHDOCS=orchdocs
MINIO_BUCKET_REPORTS=reports

# ============================================================================
# OPA (Open Policy Agent)
# ============================================================================
OPA_URL=http://localhost:8181

# ============================================================================
# Grafana
# ============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_changeme
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=

# ============================================================================
# Prometheus
# ============================================================================
PROMETHEUS_URL=http://localhost:9090

# ============================================================================
# GitHub Integration
# ============================================================================
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================================
# AI Providers
# ============================================================================
# Claude (Anthropic) - Primary
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT - Fallback
OPENAI_API_KEY=sk-...

# Google Gemini - Cost-effective
GOOGLE_API_KEY=AIza...

# ============================================================================
# Application Config
# ============================================================================
SECRET_KEY=changeme_secret_key_minimum_32_characters_random
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# JWT Authentication
# ============================================================================
JWT_SECRET_KEY=dev-secret-key-change-in-production-minimum-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================================================
# Optional: Email (for notifications)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@sdlc-orchestrator.com

# ============================================================================
# Optional: Slack (for notifications)
# ============================================================================
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
