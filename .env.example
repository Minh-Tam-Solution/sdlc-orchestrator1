# SDLC Orchestrator - Environment Variables Template
# Copy this file to .env and update values

# ============================================================================
# Database (PostgreSQL)
# ============================================================================
POSTGRES_PASSWORD=changeme_secure_password_min_16_chars
DATABASE_URL=postgresql://sdlc_user:${POSTGRES_PASSWORD}@localhost:5432/sdlc_orchestrator

# ============================================================================
# Redis
# ============================================================================
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0

# ============================================================================
# MinIO (S3-Compatible Storage)
# ============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_changeme_16_chars
MINIO_ENDPOINT=localhost:9000
MINIO_USE_SSL=false
MINIO_BUCKET_EVIDENCE=evidence-vault
MINIO_BUCKET_ORCHDOCS=orchdocs
MINIO_BUCKET_REPORTS=reports

# ============================================================================
# OPA (Open Policy Agent)
# ============================================================================
OPA_URL=http://localhost:8181

# ============================================================================
# Grafana
# ============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_changeme
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=

# ============================================================================
# Prometheus
# ============================================================================
PROMETHEUS_URL=http://localhost:9090

# ============================================================================
# GitHub Integration
# ============================================================================
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================================
# AI Providers
# ============================================================================
# Claude (Anthropic) - Primary
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT - Fallback
OPENAI_API_KEY=sk-...

# Google Gemini - Cost-effective
GOOGLE_API_KEY=AIza...

# ============================================================================
# Governance Config (Sprint 114-116 - Anti-Vibecoding)
# ============================================================================
# Enforcement levels: off, warning, soft, full
# - off: No governance checks (development mode)
# - warning: Log violations, don't block (observability mode) ← Sprint 114 COMPLETE
# - soft: Block critical violations, warn on others ← Sprint 115 ACTIVE
# - full: Block all violations (production mode) ← Sprint 116 READY
GOVERNANCE_MODE=soft

# Kill switch thresholds (auto-rollback to WARNING if exceeded)
GOVERNANCE_KILL_SWITCH_REJECTION_RATE=0.8
GOVERNANCE_KILL_SWITCH_LATENCY_P95_MS=500
GOVERNANCE_KILL_SWITCH_FALSE_POSITIVE_RATE=0.2

# ============================================================================
# Sprint 115 SOFT Mode Configuration
# ============================================================================
# Signal weights (must sum to 1.0)
GOVERNANCE_SIGNAL_ARCHITECTURAL_SMELL_WEIGHT=0.25
GOVERNANCE_SIGNAL_ABSTRACTION_COMPLEXITY_WEIGHT=0.15
GOVERNANCE_SIGNAL_AI_DEPENDENCY_RATIO_WEIGHT=0.20
GOVERNANCE_SIGNAL_CHANGE_SURFACE_AREA_WEIGHT=0.25
GOVERNANCE_SIGNAL_DRIFT_VELOCITY_WEIGHT=0.15

# Exemption rules (true/false)
GOVERNANCE_DEPENDENCY_EXEMPTION=true
GOVERNANCE_DOCS_AUTO_APPROVE=true
GOVERNANCE_TEST_ONLY_EXEMPTION=true

# Zone thresholds
GOVERNANCE_ZONE_GREEN_MAX=30
GOVERNANCE_ZONE_YELLOW_MAX=60
GOVERNANCE_ZONE_ORANGE_MAX=80

# Block rules (SOFT mode - Sprint 115)
GOVERNANCE_BLOCK_MISSING_OWNERSHIP=true
GOVERNANCE_BLOCK_MISSING_INTENT=true
GOVERNANCE_BLOCK_SECURITY_CRITICAL=true
GOVERNANCE_BLOCK_RED_ZONE=true

# ============================================================================
# Sprint 116 FULL Mode Preview (Feb 17, 2026)
# ============================================================================
# FULL mode stricter approval requirements:
# - GREEN (0-30): Auto-approve (same as SOFT)
# - YELLOW (31-60): REQUIRES Tech Lead approval (24h timeout)
# - ORANGE (61-80): REQUIRES CEO approval (48h timeout)
# - RED (81-100): BLOCKED (CTO+CEO override required)
#
# GOVERNANCE_FULL_MODE_YELLOW_TIMEOUT_HOURS=24
# GOVERNANCE_FULL_MODE_ORANGE_TIMEOUT_HOURS=48
# GOVERNANCE_FULL_MODE_COVERAGE_DROP_THRESHOLD=-5
#
# CEO Time Tracking (FULL mode):
# GOVERNANCE_CEO_BASELINE_HOURS=40
# GOVERNANCE_CEO_TARGET_HOURS=10
# GOVERNANCE_CEO_TARGET_REDUCTION_PERCENT=75
#
# Stricter Kill Switch (FULL mode):
# GOVERNANCE_KILL_SWITCH_REJECTION_RATE=0.5  # vs 0.8 in SOFT
# GOVERNANCE_KILL_SWITCH_FALSE_POSITIVE_RATE=0.15  # vs 0.2 in SOFT
# GOVERNANCE_KILL_SWITCH_DEVELOPER_COMPLAINTS=3  # vs 5 in SOFT
# GOVERNANCE_KILL_SWITCH_CEO_OVERRIDES=5  # New in FULL mode

# ============================================================================
# Application Config
# ============================================================================
SECRET_KEY=changeme_secret_key_minimum_32_characters_random
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# JWT Authentication
# ============================================================================
JWT_SECRET_KEY=dev-secret-key-change-in-production-minimum-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================================================
# Optional: Email (for notifications)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@sdlc-orchestrator.com

# ============================================================================
# Optional: Slack (for notifications)
# ============================================================================
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
