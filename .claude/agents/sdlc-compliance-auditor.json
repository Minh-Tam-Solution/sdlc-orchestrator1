  },

  "sdlc_606_features": {
    "claude_md_standard": {
      "description": "3-tier CLAUDE.md structure for AI-assisted development (LITE/PRO/ENTERPRISE)",
      "framework_doc": "03-AI-GOVERNANCE/10-CLAUDE-MD-STANDARD.md",
      "ring": "Core (timeless methodology, tool-agnostic)",
      "tiers": {
        "LITE": "500-1,000 lines — Project overview, tech stack, key commands, constraints",
        "PRO": "1,500-3,000 lines — + Module zones, debugging patterns, test commands, integration map",
        "ENTERPRISE": "2,000+ lines + supplementary files — + Cross-system deps, compliance checklists, runbooks, security boundaries"
      },
      "content_principles": [
        "Living documentation (updated every sprint)",
        "Progressive disclosure (4 layers: Quickstart → Patterns → Architecture → Deep Dive)",
        "Action-oriented (file paths + commands, not abstract philosophy)",
        "Constraint-first (hard constraints appear early)"
      ],
      "validation_criteria": {
        "LITE": "AI can run dev server in 5 min, locate 3 key files, identify 2 constraints",
        "PRO": "AI can implement <50 LOC feature in 15 min, diagnose known bug, run module tests",
        "ENTERPRISE": "AI can locate root cause in 500K+ LOC in 20 min, determine compliance implications"
      }
    },
    "autonomous_codegen_patterns": {
      "description": "Two-agent pattern with 4-Gate Quality Pipeline for governed AI code generation",
      "framework_doc": "03-AI-GOVERNANCE/11-AUTONOMOUS-CODEGEN-PATTERNS.md",
      "ring": "Core (timeless methodology, tool-agnostic)",
      "two_agent_pattern": {
        "agent_1_initializer": "Reads spec → generates feature list (single session, 10-20 min)",
        "agent_2_coding": "Implements features → runs tests → updates status (multiple sessions, 5-10 min each)"
      },
      "four_gate_pipeline": {
        "G1": "Specification Review — legal clearance, stakeholder sign-off, scope validation",
        "G2": "Security Scan — SAST, dependency audit, secret detection (per feature)",
        "G3": "Test Validation — coverage >80%, integration tests, regression (per feature)",
        "G4": "Human Review — architect review for >500 LOC, MRP complete, evidence linked"
      },
      "retry_logic": {
        "max_retries": 3,
        "feedback": "Deterministic structured error data",
        "escalation": "Human with full context on max retries exceeded"
      },
      "evidence_lifecycle": "generated → validating → [retrying] → evidence_locked → awaiting_review → merged | escalated → aborted"
    },
    "mrp_template": {
      "description": "Merge-Readiness Package — 5-section evidence-linked merge documentation",
      "framework_doc": "02-Core-Methodology/SDLC-MRP-Template.md",
      "ring": "Governance (stable process artifact, tool-agnostic)",
      "five_sections": {
        "section_1": "Change Summary — what changed, why, impact scope (max 100 words)",
        "section_2": "Evidence Vault References — gate-by-gate evidence IDs with status",
        "section_3": "Rollback Plan — trigger, steps, data migration, estimated time, verification",
        "section_4": "Testing Evidence — unit, integration, manual QA, performance",
        "section_5": "Deployment Notes — config changes, deployment order, post-deploy validation, feature flags"
      },
      "tier_requirements": {
        "LITE": "Sections 1, 3, 4 required",
        "STANDARD": "Sections 1, 2, 3, 4 required",
        "PRO": "All 5 sections required",
        "ENTERPRISE": "All 5 sections required"
      },
      "lifecycle": "DRAFT → REVIEW → APPROVED → ARCHIVED (with REVISION_REQUESTED loop)",
      "gate_g4_enforcement": "Block merge if MRP missing, sections incomplete, or evidence IDs invalid"
    },
    "three_ring_enforcement": {
      "description": "Strengthened 3-Ring Architecture compliance validation",
      "core_ring": "Timeless methodology — stages, gates, evidence principles (NEVER references specific tools)",
      "governance_ring": "Stable policies — quality gates, compliance rules (evolves slowly)",
      "outer_ring": "Tool-specific implementations — platform CLIs, infrastructure code (NOT in Framework)",
      "violation_patterns": [
        "Platform CLI references in Framework docs (e.g., sdlcctl, kubectl)",
        "Specific tool names as requirements (e.g., 'must use OPA' vs 'policy-as-code engine')",
        "Infrastructure URLs in methodology docs (e.g., api.sdlc.dev)",
        "Sprint/timeline numbers in timeless methodology",
        "Vendor-specific SDK code in Framework standards"
      ]
    }
  },

