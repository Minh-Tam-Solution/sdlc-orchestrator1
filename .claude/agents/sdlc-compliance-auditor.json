  "workflows": {
    "claude_md_standard_audit": {
      "description": "Validate CLAUDE.md against SDLC 6.0.6 3-tier standard (LITE/PRO/ENTERPRISE)",
      "duration": "30 minutes",
      "framework_ref": "03-AI-GOVERNANCE/10-CLAUDE-MD-STANDARD.md",
      "steps": [
        "detect_project_tier_from_team_size_and_complexity",
        "check_claude_md_exists_at_project_root",
        "validate_required_sections_for_tier",
        "verify_file_paths_reference_real_files",
        "verify_commands_are_executable",
        "check_constraints_section_nonempty",
        "validate_progressive_disclosure_layers",
        "check_action_oriented_content",
        "verify_last_updated_within_sprint",
        "generate_claude_md_compliance_report"
      ],
      "validation_rules": {
        "LITE_required_sections": ["Project Overview", "Tech Stack", "Quick Start", "Architecture Summary", "Top 5 Decisions", "Top 10 Tasks", "Constraints", "Emergency Contacts"],
        "PRO_additional_sections": ["Module Zones (6-10)", "Debugging Patterns", "Test Commands", "Onboarding Checklist", "Integration Map"],
        "ENTERPRISE_additional": ["System Decomposition", "Cross-System Dependencies", "Compliance Checklists", "Runbook Library", "Change Impact Matrix", "Security Boundary Map"],
        "anti_patterns": ["information_dump_10k_lines", "stale_documentation", "abstract_philosophy", "copy_paste_readme"]
      }
    },

    "autonomous_codegen_audit": {
      "description": "Validate codegen pipeline against SDLC 6.0.6 4-Gate methodology",
      "duration": "1 hour",
      "framework_ref": "03-AI-GOVERNANCE/11-AUTONOMOUS-CODEGEN-PATTERNS.md",
      "steps": [
        "verify_two_agent_separation",
        "validate_gate_g1_spec_review_integration",
        "validate_gate_g2_security_scan_per_feature",
        "validate_gate_g3_test_validation_per_feature",
        "validate_gate_g4_human_review_threshold",
        "check_retry_logic_max_3_with_deterministic_feedback",
        "verify_evidence_lifecycle_states",
        "check_escalation_path_to_human",
        "validate_policy_as_code_integration",
        "generate_codegen_compliance_report"
      ],
      "quality_gates": {
        "gate_g1_spec_review": "100% specs reviewed before coding",
        "gate_g2_sast_scan": "0 critical findings per feature",
        "gate_g3_test_coverage": ">80% for new code",
        "gate_g4_human_review": "100% for >500 LOC",
        "max_retries": 3,
        "escalation_rate": "<5%"
      }
    },

    "mrp_compliance_audit": {
      "description": "Validate Merge-Readiness Packages against SDLC 6.0.6 5-section template",
      "duration": "30 minutes",
      "framework_ref": "02-Core-Methodology/SDLC-MRP-Template.md",
      "steps": [
        "scan_prs_for_mrp_presence",
        "validate_5_section_completeness",
        "verify_evidence_vault_references_valid",
        "check_rollback_plan_executable",
        "verify_testing_evidence_linked",
        "validate_deployment_notes_actionable",
        "check_tier_specific_requirements",
        "verify_mrp_lifecycle_state",
        "validate_gate_g4_mrp_enforcement",
        "generate_mrp_compliance_report"
      ],
      "quality_gates": {
        "mrp_presence": "100% PRs >100 LOC",
        "section_completeness": "100% required sections per tier",
        "evidence_linkage": ">=1 valid EVD-ID per gate",
        "rollback_plan": "100% executable by any on-call engineer"
      }
    },

    "three_ring_architecture_audit": {
      "description": "Validate Framework documents comply with 3-Ring Architecture (Core → Governance → Outer)",
      "duration": "30 minutes",
      "steps": [
        "scan_framework_docs_for_platform_references",
        "detect_tool_specific_cli_commands",
        "detect_infrastructure_urls",
        "detect_sprint_timeline_numbers_in_core_docs",
        "detect_vendor_sdk_code_in_methodology",
        "classify_documents_by_ring",
        "verify_core_ring_tool_agnostic",
        "verify_governance_ring_stable",
        "generate_three_ring_compliance_report"
