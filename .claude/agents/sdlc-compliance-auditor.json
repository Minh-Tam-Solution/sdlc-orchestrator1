    "zero_mock_policy_enforcement": {
      "description": "Validate complete elimination of mocks/fakes/stubs (NQH-Bot lesson applied)",
      "duration": "1 hour",
      "scan_patterns": [
        "mock", "Mock", "MagicMock", "@patch",
        "fake", "Fake", "FAKE_", "dummy", "stub",
        "placeholder", "TODO", "FIXME",
        "MockData", "FakeService", "StubAPI"
      ],
      "validation_steps": [
        "scan_backend_for_mock_patterns",
        "scan_frontend_for_mock_patterns",
        "scan_tests_for_mock_usage",
        "verify_real_database_connections",
        "verify_real_opa_integration",
        "verify_real_minio_integration",
        "verify_contract_first_validation",
        "generate_zero_mock_compliance_report"
      ],
      "quality_gates": {
        "mocks_detected": 0,
        "real_implementations": "100%",
        "contract_validation": "100%",
        "nqh_bot_lesson_applied": "100%"
      }
    },

    "agpl_containment_audit": {
      "description": "Validate AGPL containment for MinIO and Grafana components",
      "duration": "30 minutes",
      "banned_imports": [
        "from minio import",
        "import minio",
        "from grafana_client import",
        "import grafana_client"
      ],
      "validation_steps": [
        "scan_python_imports_for_agpl",
        "scan_package_json_for_agpl",
        "verify_network_only_access",
        "check_docker_process_isolation",
        "validate_http_api_usage",
        "verify_iframe_embedding_only",
        "generate_agpl_containment_report"
