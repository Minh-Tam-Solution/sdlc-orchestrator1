# =============================================================================
# SDLC Orchestrator - Production Environment Configuration
# =============================================================================
# Version: 1.0.0
# Date: November 29, 2025
# Status: APPROVED by IT Admin (dvhiep@nqh.com.vn)
# Target: NQH Infrastructure (192.168.0.223)
# Port Range: 8300-8399 (SDLC Platform)
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=SDLC Orchestrator
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1
DEBUG=false
ENVIRONMENT=production

# -----------------------------------------------------------------------------
# Backend API (Port 8300)
# Public URL: https://sdlc-api.nqh.vn
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8300
BACKEND_PORT=8300

# -----------------------------------------------------------------------------
# Frontend (Port 8310)
# Public URL: https://sdlc.nqh.vn
# -----------------------------------------------------------------------------
FRONTEND_PORT=8310
VITE_API_URL=http://localhost:8300

# -----------------------------------------------------------------------------
# PostgreSQL Database (Port 5450)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://sdlc_user:CHANGE_ME_PRODUCTION_PASSWORD@localhost:5450/sdlc_orchestrator
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# -----------------------------------------------------------------------------
# Redis Cache (Port 6395)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6395/0

# -----------------------------------------------------------------------------
# MinIO Evidence Storage (Port 9010/9011)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9010
MINIO_ACCESS_KEY=CHANGE_ME_PRODUCTION_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_PRODUCTION_SECRET_KEY
MINIO_BUCKET=evidence-vault
MINIO_SECURE=false

# -----------------------------------------------------------------------------
# OPA Policy Engine (Port 8185)
# -----------------------------------------------------------------------------
OPA_URL=http://localhost:8185

# -----------------------------------------------------------------------------
# Security Settings
# IMPORTANT: Change SECRET_KEY before production deployment!
# -----------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
ACCESS_TOKEN_EXPIRE_HOURS=1
REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# OAuth 2.0 Providers (Configure before production)
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# OAuth Redirect URLs (Production)
OAUTH_REDIRECT_URL=https://sdlc.nqh.vn/auth/callback
GITHUB_OAUTH_REDIRECT_URL=https://sdlc.nqh.vn/auth/github/callback

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=https://sdlc.nqh.vn,https://sdlc-api.nqh.vn,http://localhost:8310

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
# Prometheus metrics endpoint: :8300/metrics
# Sentry (use existing NQH Sentry instance on port 9099)
SENTRY_DSN=
# ELK Stack (Filebeat → Elasticsearch)
LOG_LEVEL=INFO

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# 1. Change all CHANGE_ME_* values before deployment
# 2. Generate SECRET_KEY: openssl rand -base64 32
# 3. Configure OAuth providers if GitHub/Google login needed
# 4. Cloudflare Tunnel routes will be added by IT Team:
#    - sdlc.nqh.vn → localhost:8310 (Frontend)
#    - sdlc-api.nqh.vn → localhost:8300 (Backend API)
# =============================================================================
