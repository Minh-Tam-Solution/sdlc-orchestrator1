{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sdlc-orchestrator.dev/schemas/sdlc-config.schema.json",
  "title": "SDLC 5.0.0 Configuration Schema",
  "description": "Configuration schema for SDLC 5.0.0 Structure Validator (sdlcctl)",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for IDE support"
    },
    "version": {
      "type": "string",
      "description": "Configuration file version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "1.0.0"
    },
    "project": {
      "type": "object",
      "description": "Project metadata",
      "properties": {
        "name": {
          "type": "string",
          "description": "Project name",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "description": "Project description",
          "maxLength": 500
        },
        "repository": {
          "type": "string",
          "description": "Repository URL",
          "format": "uri"
        }
      },
      "required": ["name"]
    },
    "tier": {
      "type": "string",
      "description": "Project tier classification based on team size and complexity",
      "enum": ["lite", "standard", "professional", "enterprise"],
      "default": "professional"
    },
    "team_size": {
      "type": "integer",
      "description": "Number of team members (used for tier auto-detection if tier not specified)",
      "minimum": 1,
      "maximum": 1000
    },
    "docs_root": {
      "type": "string",
      "description": "Documentation folder path relative to project root",
      "default": "docs",
      "pattern": "^[a-zA-Z0-9_\\-/]+$"
    },
    "strict": {
      "type": "boolean",
      "description": "Enable strict mode (fail on warnings in addition to errors)",
      "default": false
    },
    "validation": {
      "type": "object",
      "description": "Validation behavior settings",
      "properties": {
        "fail_on_error": {
          "type": "boolean",
          "description": "Fail CI/CD pipeline on validation errors",
          "default": true
        },
        "fail_on_warning": {
          "type": "boolean",
          "description": "Fail CI/CD pipeline on validation warnings",
          "default": false
        },
        "required_score": {
          "type": "integer",
          "description": "Minimum compliance score required (0-100)",
          "minimum": 0,
          "maximum": 100,
          "default": 80
        }
      },
      "additionalProperties": false
    },
    "stages": {
      "type": "object",
      "description": "Stage configuration",
      "properties": {
        "enabled": {
          "type": "array",
          "description": "List of enabled stage IDs",
          "items": {
            "type": "string",
            "pattern": "^(0[0-9]|10)$"
          },
          "uniqueItems": true,
          "default": ["00", "01", "02", "03", "04", "05", "06", "07", "08", "09", "10"]
        },
        "custom_names": {
          "type": "object",
          "description": "Custom stage names (override defaults)",
          "additionalProperties": {
            "type": "string",
            "maxLength": 50
          }
        }
      },
      "additionalProperties": false
    },
    "p0_artifacts": {
      "type": "object",
      "description": "P0 artifact configuration",
      "properties": {
        "required": {
          "type": "boolean",
          "description": "Require P0 artifacts for compliance",
          "default": true
        },
        "custom_paths": {
          "type": "object",
          "description": "Custom paths for P0 artifacts (override defaults)",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "ci": {
      "type": "object",
      "description": "CI/CD integration settings",
      "properties": {
        "comment_on_pr": {
          "type": "boolean",
          "description": "Post validation results as PR comment",
          "default": true
        },
        "update_badge": {
          "type": "boolean",
          "description": "Update status badge on main branch",
          "default": true
        },
        "block_merge_on_fail": {
          "type": "boolean",
          "description": "Block PR merge if validation fails",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "ignore": {
      "type": "array",
      "description": "Glob patterns for files/folders to ignore during validation",
      "items": {
        "type": "string"
      },
      "default": [
        "**/node_modules/**",
        "**/.git/**",
        "**/dist/**",
        "**/build/**"
      ]
    }
  },
  "required": ["tier"],
  "additionalProperties": false,
  "examples": [
    {
      "tier": "lite",
      "docs_root": "docs",
      "team_size": 2
    },
    {
      "tier": "professional",
      "docs_root": "docs",
      "strict": true,
      "validation": {
        "fail_on_error": true,
        "required_score": 90
      }
    },
    {
      "tier": "enterprise",
      "docs_root": "documentation",
      "p0_artifacts": {
        "required": true
      },
      "ci": {
        "comment_on_pr": true,
        "update_badge": true,
        "block_merge_on_fail": true
      }
    }
  ]
}
