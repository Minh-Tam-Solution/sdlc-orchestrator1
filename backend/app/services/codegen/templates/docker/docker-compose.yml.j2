# Generated by SDLC Orchestrator EP-06 IR Processor
version: '3.8'

services:
  app:
    build: .
    container_name: {{ app_name }}_app
    ports:
      - "8000:8000"
    environment:
      - DATABASE_URL=postgresql+asyncpg://{{ database.name | default('app') }}:password@db:5432/{{ database.name | default('app') }}
    depends_on:
      db:
        condition: service_healthy
    networks:
      - {{ app_name }}_network

  db:
    image: postgres:15-alpine
    container_name: {{ app_name }}_db
    environment:
      - POSTGRES_USER={{ database.name | default('app') }}
      - POSTGRES_PASSWORD=password
      - POSTGRES_DB={{ database.name | default('app') }}
    volumes:
      - {{ app_name }}_postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ database.name | default('app') }}"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      - {{ app_name }}_network

networks:
  {{ app_name }}_network:
    driver: bridge

volumes:
  {{ app_name }}_postgres_data:
