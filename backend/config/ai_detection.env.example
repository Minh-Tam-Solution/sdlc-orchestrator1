# AI Detection Service Configuration
# Sprint 42 - AI Detection & Validation Pipeline
# Framework: SDLC 5.1.1

# =============================================================================
# DETECTION THRESHOLD
# =============================================================================
# Controls the sensitivity of AI detection
# Higher values = fewer false positives, more false negatives
# Lower values = more detections, potentially more false positives
#
# Recommended values:
#   0.35 - Recall-focused (catch more AI, higher FP risk)
#   0.50 - Balanced (default, production recommended)
#   0.65 - Precision-focused (fewer FP, may miss some AI)
AI_DETECTION_THRESHOLD=0.50

# =============================================================================
# SHADOW MODE
# =============================================================================
# Shadow mode logs detection results without affecting PRs
# Enable for production validation before full rollout

# Enable/disable shadow mode (true/false)
AI_DETECTION_SHADOW_MODE=true

# Percentage of PRs to analyze (0.0-1.0)
# 1.0 = 100% sampling
# 0.1 = 10% sampling (for high-volume environments)
AI_DETECTION_SHADOW_SAMPLE_RATE=1.0

# Logging level for shadow mode (DEBUG, INFO, WARNING)
AI_DETECTION_SHADOW_LOG_LEVEL=INFO

# Collect Prometheus metrics in shadow mode
AI_DETECTION_SHADOW_METRICS=true

# =============================================================================
# CIRCUIT BREAKER
# =============================================================================
# Circuit breaker protects against cascading failures when external APIs fail

# Enable/disable circuit breaker (true/false)
CIRCUIT_BREAKER_ENABLED=true

# Number of consecutive failures before opening circuit
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Seconds to wait before attempting recovery
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30.0

# Number of successes required to close circuit from half-open
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3

# =============================================================================
# PERFORMANCE
# =============================================================================
# Target: <600ms p95 latency for detection

# Maximum time (seconds) to wait for detection strategies
AI_DETECTION_TIMEOUT=5.0

# Enable parallel execution of detection strategies
AI_DETECTION_PARALLEL=true

# =============================================================================
# LOGGING
# =============================================================================
# Structured logging configuration

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable JSON logging format (true for production)
LOG_JSON_FORMAT=true

# Include detection evidence in logs (may be verbose)
LOG_INCLUDE_EVIDENCE=false
