{
  "name": "sdlc-orchestrator",
  "displayName": "SDLC Orchestrator",
  "description": "Gate status monitoring, compliance assistance, and AI-powered development for SDLC 6.0.2 governance platform with E2E API Testing support",
  "version": "1.6.2",
  "publisher": "mtsolution",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Minh-Tam-Solution/SDLC-Orchestrator"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "sdlc",
    "governance",
    "compliance",
    "quality gates",
    "ai assistant"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e293b",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "sdlc-orchestrator.gate",
        "name": "gate",
        "fullName": "SDLC Gate Assistant",
        "description": "Compliance and gate evaluation assistance for SDLC 6.0.2 (G0-G5, E2E Testing)",
        "isSticky": true,
        "commands": [
          {
            "name": "status",
            "description": "Show current gate status for the active project"
          },
          {
            "name": "evaluate",
            "description": "Evaluate current compliance and show violations"
          },
          {
            "name": "fix",
            "description": "Get AI recommendation to fix a violation"
          },
          {
            "name": "council",
            "description": "Request AI Council deliberation for critical violations"
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sdlc-explorer",
          "title": "SDLC Orchestrator",
          "icon": "media/sdlc-icon.svg"
        }
      ]
    },
    "views": {
      "sdlc-explorer": [
        {
          "id": "sdlc-context",
          "name": "Context Overlay",
          "icon": "$(dashboard)",
          "contextualTitle": "SDLC Context",
          "visibility": "visible"
        },
        {
          "id": "sdlc-gate-status",
          "name": "Gate Status",
          "icon": "$(checklist)",
          "contextualTitle": "SDLC Gate Status"
        },
        {
          "id": "sdlc-violations",
          "name": "Violations",
          "icon": "$(warning)",
          "contextualTitle": "Compliance Violations"
        },
        {
          "id": "sdlc-projects",
          "name": "Projects",
          "icon": "$(folder)",
          "contextualTitle": "SDLC Projects",
          "when": "sdlc.projectsPanelVisible"
        },
        {
          "id": "sdlc-blueprint",
          "name": "Blueprint",
          "icon": "$(package)",
          "contextualTitle": "App Blueprint"
        }
      ]
    },
    "commands": [
      {
        "command": "sdlc.refreshGates",
        "title": "Refresh Gate Status",
        "category": "SDLC",
        "icon": "$(refresh)"
      },
      {
        "command": "sdlc.openGate",
        "title": "Open Gate in Browser",
        "category": "SDLC",
        "icon": "$(link-external)"
      },
      {
        "command": "sdlc.selectProject",
        "title": "Select Project",
        "category": "SDLC",
        "icon": "$(folder-opened)"
      },
      {
        "command": "sdlc.login",
        "title": "Login to SDLC Orchestrator",
        "category": "SDLC",
        "icon": "$(sign-in)"
      },
      {
        "command": "sdlc.logout",
        "title": "Logout from SDLC Orchestrator",
        "category": "SDLC",
        "icon": "$(sign-out)"
      },
      {
        "command": "sdlc.showViolationDetails",
        "title": "Show Violation Details",
        "category": "SDLC",
        "icon": "$(info)"
      },
      {
        "command": "sdlc.fixViolation",
        "title": "Get AI Fix for Violation",
        "category": "SDLC",
        "icon": "$(lightbulb)"
      },
      {
        "command": "sdlc.init",
        "title": "Initialize SDLC Project",
        "category": "SDLC",
        "icon": "$(rocket)"
      },
      {
        "command": "sdlc.initOffline",
        "title": "Initialize SDLC Project (Offline)",
        "category": "SDLC",
        "icon": "$(rocket)"
      },
      {
        "command": "sdlc.reinit",
        "title": "Reinitialize SDLC Project",
        "category": "SDLC",
        "icon": "$(refresh)"
      },
      {
        "command": "sdlc.gapAnalysis",
        "title": "Run SDLC Gap Analysis",
        "category": "SDLC",
        "icon": "$(search)"
      },
      {
        "command": "sdlc.generate",
        "title": "Generate from Blueprint",
        "category": "SDLC",
        "icon": "$(code)"
      },
      {
        "command": "sdlc.magic",
        "title": "Magic Mode (Natural Language)",
        "category": "SDLC",
        "icon": "$(wand)"
      },
      {
        "command": "sdlc.lock",
        "title": "Lock Contract Spec",
        "category": "SDLC",
        "icon": "$(lock)"
      },
      {
        "command": "sdlc.unlock",
        "title": "Unlock Contract Spec",
        "category": "SDLC",
        "icon": "$(unlock)"
      },
      {
        "command": "sdlc.preview",
        "title": "Preview Generated Code",
        "category": "SDLC",
        "icon": "$(preview)"
      },
      {
        "command": "sdlc.resume",
        "title": "Resume Failed Generation",
        "category": "SDLC",
        "icon": "$(debug-restart)"
      },
      {
        "command": "sdlc.openAppBuilder",
        "title": "Open App Builder",
        "category": "SDLC",
        "icon": "$(window)"
      },
      {
        "command": "sdlc.blueprint.addModule",
        "title": "Add Module to Blueprint",
        "category": "SDLC",
        "icon": "$(add)"
      },
      {
        "command": "sdlc.blueprint.removeModule",
        "title": "Remove Module from Blueprint",
        "category": "SDLC",
        "icon": "$(trash)"
      },
      {
        "command": "sdlc.blueprint.addEntity",
        "title": "Add Entity to Module",
        "category": "SDLC",
        "icon": "$(add)"
      },
      {
        "command": "sdlc.blueprint.removeEntity",
        "title": "Remove Entity",
        "category": "SDLC",
        "icon": "$(trash)"
      },
      {
        "command": "sdlc.blueprint.editMetadata",
        "title": "Edit Blueprint Metadata",
        "category": "SDLC",
        "icon": "$(edit)"
      },
      {
        "command": "sdlc.showGenerationPanel",
        "title": "Show Generation Panel",
        "category": "SDLC",
        "icon": "$(pulse)"
      },
      {
        "command": "sdlc.refreshContext",
        "title": "Refresh Context Overlay",
        "category": "SDLC",
        "icon": "$(refresh)"
      },
      {
        "command": "sdlc.showContextDetails",
        "title": "Show Context Details",
        "category": "SDLC",
        "icon": "$(info)"
      },
      {
        "command": "sdlc.copyContextAsPRComment",
        "title": "Copy Context as PR Comment",
        "category": "SDLC",
        "icon": "$(clippy)"
      },
      {
        "command": "sdlc.validateSpec",
        "title": "Validate Specification (SDLC 6.0.2)",
        "category": "SDLC",
        "icon": "$(check-all)"
      },
      {
        "command": "sdlc.validateSpecWithTier",
        "title": "Validate Specification with Tier Selection",
        "category": "SDLC",
        "icon": "$(checklist)"
      },
      {
        "command": "sdlc.showSpecValidationResults",
        "title": "Show Spec Validation Results",
        "category": "SDLC",
        "icon": "$(output)"
      },
      {
        "command": "sdlc.connectGithub",
        "title": "Connect GitHub Repository",
        "category": "SDLC",
        "icon": "$(github)"
      },
      {
        "command": "sdlc.disconnectGithub",
        "title": "Disconnect GitHub Repository",
        "category": "SDLC",
        "icon": "$(github)"
      },
      {
        "command": "sdlc.syncGithub",
        "title": "Sync GitHub Repository",
        "category": "SDLC",
        "icon": "$(sync)"
      },
      {
        "command": "sdlc.scanGithubRepo",
        "title": "Scan GitHub Repository",
        "category": "SDLC",
        "icon": "$(search)"
      },
      {
        "command": "sdlc.e2eValidate",
        "title": "E2E: Validate Testing Compliance",
        "category": "SDLC",
        "icon": "$(beaker)"
      },
      {
        "command": "sdlc.e2eCrossReference",
        "title": "E2E: Validate Cross-References",
        "category": "SDLC",
        "icon": "$(references)"
      },
      {
        "command": "sdlc.e2eInit",
        "title": "E2E: Initialize Testing Structure",
        "category": "SDLC",
        "icon": "$(folder-opened)"
      },
      {
        "command": "sdlc.e2eValidateWithOptions",
        "title": "E2E: Validate with Options",
        "category": "SDLC",
        "icon": "$(gear)"
      },
      {
        "command": "sdlc.showE2EResults",
        "title": "E2E: Show Validation Results",
        "category": "SDLC",
        "icon": "$(output)"
      },
      {
        "command": "sdlc.checkSSOT",
        "title": "SDLC: Check SSOT Compliance",
        "category": "SDLC",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "sdlc.fixSSOT",
        "title": "SDLC: Fix SSOT Violations",
        "category": "SDLC",
        "icon": "$(wrench)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sdlc.refreshContext",
          "when": "view == sdlc-context",
          "group": "navigation"
        },
        {
          "command": "sdlc.copyContextAsPRComment",
          "when": "view == sdlc-context",
          "group": "navigation"
        },
        {
          "command": "sdlc.refreshGates",
          "when": "view == sdlc-gate-status",
          "group": "navigation"
        },
        {
          "command": "sdlc.selectProject",
          "when": "view == sdlc-projects",
          "group": "navigation"
        },
        {
          "command": "sdlc.blueprint.addModule",
          "when": "view == sdlc-blueprint",
          "group": "navigation"
        },
        {
          "command": "sdlc.openAppBuilder",
          "when": "view == sdlc-blueprint",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "sdlc.openGate",
          "when": "view == sdlc-gate-status && viewItem == gate",
          "group": "inline"
        },
        {
          "command": "sdlc.fixViolation",
          "when": "view == sdlc-violations && viewItem == violation",
          "group": "inline"
        },
        {
          "command": "sdlc.blueprint.addEntity",
          "when": "view == sdlc-blueprint && viewItem == module",
          "group": "inline"
        },
        {
          "command": "sdlc.blueprint.removeModule",
          "when": "view == sdlc-blueprint && viewItem == module",
          "group": "inline"
        },
        {
          "command": "sdlc.blueprint.removeEntity",
          "when": "view == sdlc-blueprint && viewItem == entity",
          "group": "inline"
        },
        {
          "command": "sdlc.blueprint.editMetadata",
          "when": "view == sdlc-blueprint && viewItem == blueprint",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "sdlc.refreshGates",
          "when": "sdlc.isAuthenticated"
        },
        {
          "command": "sdlc.selectProject",
          "when": "sdlc.isAuthenticated"
        },
        {
          "command": "sdlc.logout",
          "when": "sdlc.isAuthenticated"
        },
        {
          "command": "sdlc.login",
          "when": "!sdlc.isAuthenticated"
        },
        {
          "command": "sdlc.connectGithub",
          "when": "sdlc.isAuthenticated"
        },
        {
          "command": "sdlc.disconnectGithub",
          "when": "sdlc.isAuthenticated"
        },
        {
          "command": "sdlc.syncGithub",
          "when": "sdlc.isAuthenticated"
        },
        {
          "command": "sdlc.scanGithubRepo",
          "when": "sdlc.isAuthenticated"
        }
      ]
    },
    "configuration": {
      "title": "SDLC Orchestrator",
      "properties": {
        "sdlc.apiUrl": {
          "type": "string",
          "default": "https://sdlc.nhatquangholding.com",
          "description": "SDLC Orchestrator API base URL",
          "order": 1
        },
        "sdlc.autoRefreshInterval": {
          "type": "number",
          "default": 30,
          "minimum": 10,
          "maximum": 300,
          "description": "Auto-refresh interval for gate status (seconds)",
          "order": 2
        },
        "sdlc.defaultProjectId": {
          "type": "string",
          "default": "",
          "description": "Default project ID to load on startup",
          "order": 3
        },
        "sdlc.enableNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications for gate status changes",
          "order": 4
        },
        "sdlc.aiCouncilEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI Council for critical/high severity violations",
          "order": 5
        },
        "sdlc.showViolationBadge": {
          "type": "boolean",
          "default": true,
          "description": "Show violation count badge in activity bar",
          "order": 6
        },
        "sdlc.validateSpecOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically validate specification files on save (SDLC 6.0.0)",
          "order": 7
        },
        "sdlc.defaultSpecTier": {
          "type": "string",
          "default": "PROFESSIONAL",
          "enum": [
            "LITE",
            "STANDARD",
            "PROFESSIONAL",
            "ENTERPRISE"
          ],
          "enumDescriptions": [
            "Minimal governance (1-2 people, 4 stages)",
            "Basic governance (3-10 people, 6 stages)",
            "Full governance (10-50 people, 10 stages)",
            "Complete governance (50+ people, 11 stages)"
          ],
          "description": "Default tier for specification validation",
          "order": 8
        },
        "sdlc.showProjectsPanel": {
          "type": "boolean",
          "default": false,
          "description": "Always show Projects panel even when project is auto-detected (Sprint 127)",
          "order": 9
        }
      }
    },
    "keybindings": [
      {
        "command": "sdlc.refreshGates",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "sdlc.isAuthenticated"
      },
      {
        "command": "sdlc.init",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      },
      {
        "command": "sdlc.generate",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g",
        "when": "sdlc.isAuthenticated"
      },
      {
        "command": "sdlc.magic",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "sdlc.isAuthenticated"
      },
      {
        "command": "sdlc.lock",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "sdlc.isAuthenticated"
      },
      {
        "command": "sdlc.preview",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "sdlc.isAuthenticated"
      },
      {
        "command": "sdlc.openAppBuilder",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "sdlc.isAuthenticated"
      },
      {
        "command": "sdlc.validateSpec",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId == markdown"
      },
      {
        "command": "sdlc.e2eValidate",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e"
      }
    ],
    "colors": [
      {
        "id": "sdlc.gateApproved",
        "description": "Color for approved gates",
        "defaults": {
          "dark": "#22c55e",
          "light": "#16a34a",
          "highContrast": "#22c55e"
        }
      },
      {
        "id": "sdlc.gatePending",
        "description": "Color for pending gates",
        "defaults": {
          "dark": "#eab308",
          "light": "#ca8a04",
          "highContrast": "#eab308"
        }
      },
      {
        "id": "sdlc.gateRejected",
        "description": "Color for rejected gates",
        "defaults": {
          "dark": "#ef4444",
          "light": "#dc2626",
          "highContrast": "#ef4444"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.54.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "js-yaml": "^4.1.1"
  }
}
